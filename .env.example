# ─────────────────────────────────────────────────────────────
# ZTAM Platform — Environment Variables
# Copy this file to .env and replace every "change_me" value.
# Use long, random strings: openssl rand -hex 32
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# PostgreSQL (used by Keycloak)
PG_PASS=change_me

# Keycloak admin credentials
KC_ADMIN_USER=admin
KC_ADMIN_PASS=change_me

# Keycloak hostname used in JWT issuer claim (must match KC_HOSTNAME)
# Local dev: localhost  |  Production: auth.yourdomain.com
KC_HOSTNAME=localhost

# Keycloak public URL (what the browser / auth-middleware sees as the issuer)
# For local dev: http://localhost:8080
# For production: https://auth.yourdomain.com
KEYCLOAK_URL=http://localhost:8080
KC_ISSUER_URL=http://localhost:8080

# Public URL of the ZTAM gateway used for browser redirects and callback URLs
# Local dev: https://localhost
# Production: https://ztam.yourdomain.com
ZTAM_PUBLIC_URL=https://localhost

# Keycloak realm/client settings
KC_REALM=test-tenant
KC_CLIENT_ID=test-app
KC_CLIENT_SECRET=change_me

# MySQL credentials (TestApp database)
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=taskapp
MYSQL_USER=taskuser
MYSQL_PASSWORD=change_me

# JWT secret shared between TestApp and auth-middleware
# Minimum 32 chars. Generate with: openssl rand -hex 64
TESTAPP_JWT_SECRET=change_me_use_long_random_string

# Cookie defaults used by auth-middleware for browser flows
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax

# Auth-middleware observability defaults
# Use LOG_FORMAT=json in production so logs are machine-readable.
LOG_FORMAT=json
ZTAM_ENVIRONMENT=dev

# Optional observability profile credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana
