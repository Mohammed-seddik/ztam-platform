# PostgreSQL (used by Keycloak)
PG_PASS=change_me

# Keycloak admin credentials
KC_ADMIN_USER=admin
KC_ADMIN_PASS=change_me

# Keycloak realm/client settings
KC_REALM=test-tenant
KC_CLIENT_ID=test-app
KC_CLIENT_SECRET=change_me
# KC_ISSUER_URL: must match the public hostname Keycloak uses (KC_HOSTNAME in docker-compose)
# Default: http://localhost:8080  (matches KC_HOSTNAME: localhost)
KC_ISSUER_URL=http://localhost:8080

# MySQL credentials (TestApp database)
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=taskapp
MYSQL_USER=taskuser
MYSQL_PASSWORD=change_me

# JWT secret shared between TestApp and auth-middleware
TESTAPP_JWT_SECRET=change_me_use_long_random_string
