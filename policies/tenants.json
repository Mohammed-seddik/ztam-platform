{
  "_comment": "Per-tenant permissions. Key = Keycloak client_id (= azp claim). Each tenant overrides the global policies/permissions.json fallback.",
  "testapp": {
    "roles": {
      "user": {
        "allowed_paths": [
          "/api/"
        ],
        "denied_paths": [
          "/admin/",
          "/admin"
        ],
        "allowed_methods": [
          "GET",
          "POST"
        ]
      },
      "editor": {
        "allowed_paths": [
          "/api/"
        ],
        "denied_paths": [
          "/admin/",
          "/admin"
        ],
        "allowed_methods": [
          "GET",
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "viewer": {
        "allowed_paths": [
          "/api/"
        ],
        "denied_paths": [
          "/admin/",
          "/admin"
        ],
        "allowed_methods": [
          "GET"
        ]
      }
    }
  }
}