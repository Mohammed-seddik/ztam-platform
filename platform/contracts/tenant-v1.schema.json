{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ztam.local/schemas/tenant-v1.schema.json",
  "title": "ZTAM Tenant V1",
  "type": "object",
  "required": [
    "tenant_id",
    "display_name",
    "primary_hostname",
    "backend_origin",
    "integration_mode",
    "identity_mode",
    "keycloak_realm",
    "keycloak_client_id",
    "secret_refs",
    "role_catalog",
    "policy_definition",
    "status",
    "revision",
    "created_at",
    "updated_at",
    "audit_metadata"
  ],
  "properties": {
    "tenant_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "primary_hostname": {
      "type": "string",
      "minLength": 1
    },
    "backend_origin": {
      "type": "string",
      "minLength": 1
    },
    "integration_mode": {
      "type": "string",
      "enum": ["managed_oidc", "form_bridge", "federated_db"]
    },
    "identity_mode": {
      "type": "string",
      "enum": ["managed", "federated_db"]
    },
    "keycloak_realm": {
      "type": "string",
      "minLength": 1
    },
    "keycloak_client_id": {
      "type": "string",
      "minLength": 1
    },
    "secret_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "role_catalog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "policy_definition": {
      "type": "object"
    },
    "adapter_mode": {
      "type": "string",
      "enum": ["headers", "translated_token"]
    },
    "client_change_summary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "validated", "published", "disabled"]
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "published_at": {
      "type": ["string", "null"]
    },
    "assessment": {
      "type": ["object", "null"]
    },
    "audit_metadata": {
      "type": "object"
    }
  }
}
