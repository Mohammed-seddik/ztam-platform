{
  "name": "testapp",
  "display_name": "TestApp (Demo Tenant)",
  "backend_url": "http://testapp:3000",
  "hostname": "localhost",
  "keycloak_client_id": "test-app",
  "keycloak_realm": "test-tenant",
  "roles": [
    "admin",
    "editor",
    "user",
    "viewer"
  ],
  "login_mode": "keycloak",
  "no_spi": false,
  "permissions": {
    "editor": {
      "allowed_paths": [
        "/api/"
      ],
      "allowed_exact_paths": [
        "/",
        "/dashboard.html",
        "/favicon.ico"
      ],
      "denied_paths": [
        "/admin/",
        "/admin"
      ],
      "allowed_methods": [
        "GET",
        "POST",
        "PUT",
        "PATCH",
        "DELETE"
      ]
    },
    "user": {
      "allowed_paths": [
        "/api/"
      ],
      "allowed_exact_paths": [
        "/",
        "/dashboard.html",
        "/favicon.ico"
      ],
      "denied_paths": [
        "/admin/",
        "/admin"
      ],
      "allowed_methods": [
        "GET",
        "POST",
        "DELETE"
      ]
    },
    "viewer": {
      "allowed_paths": [
        "/api/"
      ],
      "allowed_exact_paths": [
        "/",
        "/dashboard.html",
        "/favicon.ico"
      ],
      "denied_paths": [
        "/admin/",
        "/admin"
      ],
      "allowed_methods": [
        "GET"
      ]
    }
  },
  "created_at": "2026-03-06T00:00:00Z",
  "notes": "The built-in demo tenant. Backend runs inside Docker on the ztam network."
}
